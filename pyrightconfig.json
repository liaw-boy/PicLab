{
  "pythonVersion": "3.11",
  "venvPath": ".",
  "venv": ".venv",
  "include": ["src", "main.py", "tests"],
  "exclude": ["**/__pycache__", ".venv"],
  "typeCheckingMode": "basic",
  "reportMissingImports": false,
  "reportMissingModuleSource": false,
  "reportAttributeAccessIssue": "warning",
  "reportOptionalMemberAccess": "warning"
}
